#!/usr/bin/env clitest --v0

# Test: simple.toml has no rustflags, expect empty output
$ cargo-rustflags --config ${INITIAL_PWD}/simple.toml

# Test: target.toml has cfg(true) rustflags
$ cargo-rustflags --config ${INITIAL_PWD}/target.toml
! --cfg=something

# Test: include.toml includes other.toml
$ cargo-rustflags --config ${INITIAL_PWD}/include.toml
! --cfg=included

# Test: inline KEY=VALUE config still works
$ cargo-rustflags --config "target.'cfg(true)'.rustflags=[\"--cfg=inline_test\"]"
! --cfg=inline_test

# Test: multiple --config flags combine
$ cargo-rustflags --config ${INITIAL_PWD}/target.toml --config "target.'cfg(true)'.rustflags=[\"--cfg=extra\"]"
! --cfg=something --cfg=extra

# Test: --list prints one flag per line
$ cargo-rustflags --config ${INITIAL_PWD}/target.toml --config "target.'cfg(true)'.rustflags=[\"--cfg=extra\"]" --list
! --cfg=something
! --cfg=extra

# Test: -1 is shorthand for --list
$ cargo-rustflags --config ${INITIAL_PWD}/target.toml -1
! --cfg=something

# Test: --list with no flags produces no output
$ cargo-rustflags --config ${INITIAL_PWD}/simple.toml --list

# Test: -C flags are captured
$ cargo-rustflags --config "target.'cfg(true)'.rustflags=[\"-Cembed-bitcode=no\"]"
! -Cembed-bitcode=no

# Test: -Z flags on stable are captured (probe must not break)
$ cargo-rustflags --config "target.'cfg(true)'.rustflags=[\"-Zparse-only\"]"
! -Zparse-only

# Test: -W flags are captured
$ cargo-rustflags --config "target.'cfg(true)'.rustflags=[\"-Wunused\"]"
! -Wunused

# Test: mixed flag types
$ cargo-rustflags --config "target.'cfg(true)'.rustflags=[\"--cfg=mytest\", \"-Copt-level=2\", \"-Wunused\"]" --list
! --cfg=mytest
! -Copt-level=2
! -Wunused

# Test: RUSTFLAGS env var
$ RUSTFLAGS="--cfg=from_env" cargo-rustflags
! --cfg=from_env

# Test: --target resolves cross-compilation rustflags
$ cargo-rustflags --target x86_64-apple-darwin --config "target.'cfg(true)'.rustflags=[\"--cfg=cross_test\"]"
! --cfg=cross_test

# Test: --target with mixed flags
$ cargo-rustflags --target x86_64-pc-windows-msvc --config "target.'cfg(true)'.rustflags=[\"--cfg=mytest\", \"-Copt-level=2\"]"
! --cfg=mytest -Copt-level=2

# Test: --encoded produces 0x1f-separated output
$ cargo-rustflags --config "target.'cfg(true)'.rustflags=[\"--cfg=mytest\", \"-Copt-level=2\"]" --encoded
? --cfg=mytest\x1f-Copt-level=2

# Test: --encoded with single flag (no separator)
$ cargo-rustflags --config ${INITIAL_PWD}/target.toml --encoded
! --cfg=something

# Test: --encoded with no flags produces no output
$ cargo-rustflags --config ${INITIAL_PWD}/simple.toml --encoded

# Test: --list and --encoded are mutually exclusive
$ cargo-rustflags --list --encoded
%EXIT 1
? %{GREEDYDATA}mutually exclusive

# Test: unknown argument fails
$ cargo-rustflags --bogus
%EXIT 1
? %{GREEDYDATA}Unknown argument: --bogus

# Test: help flag
$ cargo-rustflags --help
%EXIT 0
? %{GREEDYDATA}KEY=VALUE|PATH%{GREEDYDATA}
*

